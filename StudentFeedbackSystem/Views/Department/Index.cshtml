@model DepartmentsVM
@{ ViewData["Title"] = "Department Management"; }

<div class="card">
    <div class="card-header"><h5><i class="bi bi-building me-2"></i>Department Management</h5></div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <form id="departmentForm">
                    <input type="hidden" asp-for="DepartmentId" value="0" />
                    <div class="mb-3">
                        <label asp-for="DepartmentCode" class="form-label"></label>
                        <input asp-for="DepartmentCode" class="form-control" />
                        <span asp-validation-for="DepartmentCode" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="DepartmentName" class="form-label"></label>
                        <input asp-for="DepartmentName" class="form-control" />
                        <span asp-validation-for="DepartmentName" class="text-danger"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" id="btnSave" class="btn btn-primary"><i class="bi bi-save me-1"></i> Save</button>
                        <button type="button" id="btnClear" class="btn btn-secondary"><i class="bi bi-arrow-counterclockwise me-1"></i> Reset</button>
                    </div>
                </form>
            </div>
            <div class="col-md-8">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Actions</th>
                            </tr>
                       </thead>
                        <tbody id="tableBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>

           $(document).ready(function () {
            loadDepartmentTable();

            $('#btnSave').click(function (e) {
                e.preventDefault();
                saveDepartment();
            });

            $('#btnClear').click(function (e) {
                e.preventDefault();
                clearDepartmentForm();
            });
        });


        function loadDepartmentTable() {
            $.ajax({
                url: '/Department/GetAll',
                type: 'GET',
                success: function (response) {
                    if (response.code === 0) {
                        renderDepartmentTable(response.data);
                    }
                }
            });
        }

            function renderDepartmentTable(data) {
            var html = '';
            $.each(data, function (i, item) {
                html += '<tr>';
                html += '<td>' + item.departmentId + '</td>';
                html += '<td><span class="badge bg-primary">' + item.departmentCode + '</span></td>';
                html += '<td>' + item.departmentName + '</td>';
                html += '<td>';
                html += '<button class="btn btn-sm btn-outline-primary" onclick="editDepartment(' + item.departmentId + ')"><i class="bi bi-pencil"></i></button> ';
                html += '<button class="btn btn-sm btn-outline-danger" onclick="deleteDepartment(' + item.departmentId + ')"><i class="bi bi-trash"></i></button>';
                html += '</td>';
                html += '</tr>';
            });
            $('#tableBody').html(html);
        }

        function saveDepartment() {
            if (!validateDepartmentForm()) return false;

            var formData = {
                DepartmentId: parseInt($('#DepartmentId').val()) || 0,
                DepartmentCode: $('#DepartmentCode').val().trim(),
                DepartmentName: $('#DepartmentName').val().trim()
            };

            $.ajax({
                url: '/Department/Save',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(formData),
                success: function (response) {
                    if (response.code == 0) {
                        Swal.fire('Success!', response.message, 'success');
                        clearDepartmentForm();
                        loadDepartmentTable();
                    } else {
                        Swal.fire('Error!', response.message, 'error');
                    }
                },
                error: function () {
                    Swal.fire('Error!', 'Something went wrong', 'error');
                }
            });
        }

        function editDepartment(id) {
            $.ajax({
                url: '/Department/GetById?id=' + id,
                type: 'GET',
                success: function (response) {
                    if (response.code == 0) {
                        $('#DepartmentId').val(response.data.departmentId);
                        $('#DepartmentCode').val(response.data.departmentCode);
                        $('#DepartmentName').val(response.data.departmentName);
                    }
                }
            });
        }

        function deleteDepartment(id) {
            Swal.fire({
                title: 'Delete?',
                text: 'This cannot be undone!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Delete'
            }).then(function (result) {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Department/Delete',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.code == 0) {
                                Swal.fire('Deleted!', response.message, 'success');
                                loadDepartmentTable();
                            } else {
                                Swal.fire('Error!', response.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    

        function validateDepartmentForm() {
            var isValid = true;
            $('.error-message').remove();
            $('.is-invalid').removeClass('is-invalid');

            if ($('#DepartmentCode').val().trim() === '') {
                showError('#DepartmentCode', 'Department Code is required');
                isValid = false;
            }
            if ($('#DepartmentName').val().trim() === '') {
                showError('#DepartmentName', 'Department Name is required');
                isValid = false;
            }

            return isValid;
        }

        function showError(selector, message) {
            $(selector).addClass('is-invalid');
            $(selector).after('<span class="error-message text-danger small">' + message + '</span>');
        }

        function clearDepartmentForm() {
            $('#DepartmentId').val(0);
            $('#DepartmentCode').val('');
            $('#DepartmentName').val('');
            $('.is-invalid').removeClass('is-invalid');
            $('.error-message').remove();
        }

    </script>
}
