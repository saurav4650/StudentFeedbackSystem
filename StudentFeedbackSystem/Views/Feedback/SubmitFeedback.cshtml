@model StudentFeedbackSystem.Models.FeedbackSubmissionVM
@{ ViewData["Title"] = "Submit Feedback"; }

<div class="card">
    <div class="card-header">
        <h5><i class="bi bi-pencil-square me-2"></i>Submit Feedback</h5>
    </div>
    <div class="card-body">
        <div class="row mb-4">
            <div class="col-md-3"><div class="stat-card" style="background:linear-gradient(135deg,#4f46e5,#7c3aed);padding:1rem;"><div class="stat-label small">Course</div><div class="fw-bold">@Model.CourseName</div></div></div>
            <div class="col-md-3"><div class="stat-card" style="background:linear-gradient(135deg,#059669,#10b981);padding:1rem;"><div class="stat-label small">Instructor</div><div class="fw-bold">@Model.InstructorName</div></div></div>
            <div class="col-md-3"><div class="stat-card" style="background:linear-gradient(135deg,#d97706,#f59e0b);padding:1rem;"><div class="stat-label small">Semester</div><div class="fw-bold">@Model.SemesterName</div></div></div>
            <div class="col-md-3"><div class="stat-card" style="background:linear-gradient(135deg,#dc2626,#ef4444);padding:1rem;"><div class="stat-label small">Section</div><div class="fw-bold">@Model.SectionNumber</div></div></div>
        </div>

        <form method="post" asp-action="SubmitFeedback">
            <input type="hidden" asp-for="ScheduleId" />
            <input type="hidden" asp-for="StudentUserId" />

            <div class="card mt-4 mb-3" style="border:2px solid var(--primary); border-radius:10px;">
                <div class="card-body">
                    <label class="form-label fw-bold" style="color:var(--primary);"><i class="bi bi-star-fill me-1"></i> Overall Rating</label>
                    <div class="star-rating" data-index="overall">
                        <input type="hidden" asp-for="OverallRating" id="rating_overall" />
                        @for (int s = 1; s <= 5; s++)
                        {
                            <i class="bi bi-star" data-value="@s" onclick="setRating('overall', @s)" style="font-size:1.5rem;"></i>
                        }
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-send me-1"></i> Submit Feedback</button>
                <a href="/Feedback" class="btn btn-outline-secondary btn-lg"><i class="bi bi-arrow-left me-1"></i> Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function setRating(index, value) {
        $('#rating_' + index).val(value);
        var container = $('[data-index="' + index + '"]');
        container.find('i').each(function () {
            var starVal = parseInt($(this).data('value'));
            if (starVal <= value) {
                $(this).removeClass('bi-star').addClass('bi-star-fill');
            } else {
                $(this).removeClass('bi-star-fill').addClass('bi-star');
            }
        });
    }
</script>
}
